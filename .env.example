# Optional contact email for polite API usage.
# OpenAlex accepts a mailto parameter and Unpaywall requires a real email.
CONTACT_EMAIL=your-email@example.com

# Optional custom SQLite cache path.
# Default: backend/data/evidencelint.db
EVIDENCELINT_CACHE_PATH=backend/data/evidencelint.db

# Optional Semantic Scholar API key.
# The app can use the public endpoint without this, but a key helps with rate limits.
SEMANTIC_SCHOLAR_API_KEY=

# Optional provider keys/tokens for higher rate limits.
OPENALEX_API_KEY=
NCBI_API_KEY=
OPENAIRE_ACCESS_TOKEN=

# BASE keyword API access usually requires registration/IP authorization.
# Keep disabled unless you have approved access.
BASE_API_ENABLED=false
